# Backend server port
PORT=5000

# Local MySQL database URL. Replace user, password and database name as needed.
# Example: mysql://root:password@127.0.0.1:3306/ocms_db
DATABASE_URL=mysql://root:password@127.0.0.1:3306/ocms_db

# JWT secret used to sign tokens (change to a secure random value in production)
JWT_SECRET=super_secret_key_123
JWT_EXPIRES_IN=1d

# Comma-separated allowed CORS origins for the frontend
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://192.168.100.88:3000

# Ensure Prisma uses the library engine. Do NOT wrap the value in quotes.
PRISMA_CLIENT_ENGINE_TYPE=library