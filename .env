# Backend server port
PORT=5000

# Local MySQL database URL. Replace user, password and database name as needed.
DATABASE_URL=mysql://root:password@127.0.0.1:3306/ocms_db

# JWT secret used to sign tokens — MUST be set to a strong random value (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_SECURE_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=1d

# Comma-separated allowed CORS origins for the frontend (no trailing slashes)
CORS_ORIGIN=http://localhost:3000

# Ensure Prisma uses the library engine. Do NOT wrap the value in quotes.
PRISMA_CLIENT_ENGINE_TYPE=library

# Environment: development | production | test
NODE_ENV=development